// Game Panel — Prisma schema.
//
// Phase 0: datasource + generator only.
// Phase 1: better-auth generates its models here (User, Session, Account,
//          Verification, Organization, Member, Invitation, ApiKey, ...) and we
//          add our org-scoped domain models (Node, Server, Egg, Allocation,
//          AddonInstall, ...) alongside them. Every domain model carries an
//          organizationId for tenant isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- better-auth managed models below (generated by @better-auth/cli) ---
// Auth + multi-tenancy tables (User, Session, Account, Verification,
// Organization, Member, Invitation, TwoFactor) are owned by better-auth and
// regenerated via `@better-auth/cli generate`. Our org-scoped domain models
// (Node, Server, Egg, Allocation, AddonInstall) get added alongside them in
// later phases, referencing Organization by organizationId.

model User {
  id               String       @id
  name             String
  email            String
  emailVerified    Boolean      @default(false)
  image            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  twoFactorEnabled Boolean?     @default(false)
  role             String?
  banned           Boolean?     @default(false)
  banReason        String?
  banExpires       DateTime?
  sessions         Session[]
  accounts         Account[]
  members          Member[]
  invitations      Invitation[]
  twofactors       TwoFactor[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  impersonatedBy       String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?
  members     Member[]
  invitations Invitation[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

// --- Domain models (ours) ---
// Org-scoped by `organizationId` (String, no Prisma relation to the better-auth
// `Organization` so the better-auth CLI can regenerate its models without
// clobbering ours). Tenant isolation is enforced in application code: every
// query filters by the caller's active organization.

/// A customer node — a machine running our daemon. The daemon dials into the
/// panel over WebSocket and authenticates with the node token (only its sha256
/// hash is stored). Live online/offline status is tracked in-memory by the
/// daemon gateway; `lastSeenAt` and reported specs are persisted here.
model Node {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  tokenHash       String    @unique
  lastSeenAt      DateTime?
  daemonVersion   String?
  dockerAvailable Boolean   @default(false)
  cpuCores        Int?
  memoryMiB       Int?
  diskMiB         Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@map("node")
}

/// A service definition (Pterodactyl-style "egg"): the Docker image, optional
/// startup command override, how to stop it, and the variables operators fill
/// in. organizationId null = a built-in/global egg available to every org.
model Egg {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  description    String?
  dockerImage    String
  startup        String   @default("")
  stopCommand    String? // stdin command sent before stop (e.g. "stop"); else SIGTERM
  variables      Json // [{ name, envVariable, defaultValue, userEditable }]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("egg")
}

/// A game server instance: one Docker container managed by a node's daemon.
/// `state` mirrors the last state the daemon reported.
model Server {
  id             String   @id @default(cuid())
  organizationId String
  nodeId         String
  eggId          String
  name           String
  dockerImage    String
  startup        String   @default("")
  stopCommand    String?
  environment    Json // resolved envVariable -> value map
  memoryMiB      Int      @default(1024)
  cpuPercent     Int      @default(100)
  diskMiB        Int      @default(5120)
  primaryPort    Int
  state          String   @default("offline")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([nodeId, primaryPort])
  @@index([organizationId])
  @@index([nodeId])
  @@map("server")
}

/// A published addon in the registry: a sandboxed WASM module + manifest. The
/// WASM runs in our control plane (Extism) with no ambient authority — it's a
/// pure input->output function and the host enforces capabilities when applying
/// the effects it returns. Curation/approval status arrives in Phase 6.
model Addon {
  id          String   @id
  name        String
  version     String
  author      String
  description String
  manifest    Json
  wasm        Bytes
  /// Marketplace curation: only published addons appear in the public registry.
  /// Bundled/first-party addons are seeded published; uploads await staff review.
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("addon")
}

/// Platform-staff moderation state for an org (we own this; the better-auth
/// Organization table stays untouched so its CLI can regenerate it). A suspended
/// org cannot create or power on servers.
model OrgModeration {
  organizationId String   @id
  suspended      Boolean  @default(false)
  reason         String?
  updatedAt      DateTime @updatedAt

  @@map("org_moderation")
}

/// An org's installation of an addon, with the capability scopes the admin
/// granted and per-install config.
model AddonInstall {
  id             String   @id @default(cuid())
  organizationId String
  addonId        String
  enabled        Boolean  @default(true)
  grantedScopes  Json // string[]
  config         Json // arbitrary key/value config for the addon
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, addonId])
  @@index([organizationId])
  @@map("addon_install")
}

/// Per-(org, addon) isolated key/value store the addon reads/writes via effects.
model AddonKv {
  id             String   @id @default(cuid())
  organizationId String
  addonId        String
  key            String
  value          String
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, addonId, key])
  @@map("addon_kv")
}

/// Addon activity feed (log lines emitted by an addon, shown in the UI).
model AddonLog {
  id             String   @id @default(cuid())
  organizationId String
  addonId        String
  level          String   @default("info")
  message        String
  createdAt      DateTime @default(now())

  @@index([organizationId, addonId])
  @@map("addon_log")
}
